<?php $this->registerJs("
    dtAfterSave();
", yii\web\View::POS_READY); ?>
<script>
function dtAfterSave(){
    var dt_table =  $('#table-open-penerimaan').dataTable({
        ajax: { url: '<?= \yii\helpers\Url::toRoute('/ppic/terimasengon/openpenerimaan') ?>?pickingfrom=<?= $pickingfrom ?>',data:{dt: 'modal-open-penerimaan'} },
        order: [
            [2, 'desc']
        ],
        columnDefs: [
            {	targets: 0, class:'td-kecil  text-align-center', 
                render: function ( data, type, full, meta ) {
                    var date = new Date(full[2]);
					date = date.toString('dd/MM/yyyy');
                    if(full[12]){ // kondisional
                        return "<a class='btn btn-xs btn-icon-only grey' style='width: 25px; height: 25px;'><i class='fa fa-plus-circle'></i></a>";
                    }else{
                        return "<a onclick='pickPenerimaanSengon(\""+full[0]+"\",\""+full[1]+"\",\""+date+"\",\""+full[3]+"\",\""+full[4]+"\",\""+full[5]+"\",\""+full[6]+"\",\""+full[7]+"\",\""+full[8]+"\",\""+full[9]+"\",\""+full[10]+"\")' class='btn btn-xs btn-icon-only btn-default' data-original-title='Pick' style='width: 25px; height: 25px;'><i class='fa fa-plus-circle'></i></a>";
                    }
					
                }
            },
            { 	targets: 1, class:"text-align-center td-kecil", },
			{ 	targets: 2, class:"text-align-center td-kecil",
                render: function ( data, type, full, meta ) {
					var date = new Date(data);
					date = date.toString('dd/MM/yyyy');
					return '<center>'+date+'</center>';
                }
            },
            { 	targets: 3, class:"text-align-left td-kecil", },
            { 	targets: 4, class:"text-align-left td-kecil", },
            { 	targets: 5, class:"text-align-left td-kecil", },
            { 	targets: 6, class:"text-align-left td-kecil", },
            { 	targets: 7, class:"text-align-right td-kecil", },
            { 	targets: 8, class:"text-align-right td-kecil", },
            { 	targets: 9, class:"text-align-right td-kecil", },
            { 	targets: 10, class:"text-align-right td-kecil",
                render: function ( data, type, full, meta ) {
					return formatNumberForUser4Digit(data);
                }
            },
            { 	targets: 11, class:"text-align-left td-kecil", },
        ],
		autoWidth: false,
		"dom": "<'row'<'col-md-6 col-sm-12'f><'col-md-6 col-sm-12'>r><'table-scrollable't><'row'<'col-md-5 col-sm-12'i><'col-md-7 col-sm-12'p>>",
    });
}

</script>