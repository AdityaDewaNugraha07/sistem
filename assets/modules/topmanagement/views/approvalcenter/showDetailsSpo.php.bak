										<tr>
											<td colspan="5" class="text-align-right" style="padding-top: 3px; padding-bottom: 3px;">Ppn</td>
											<td class="text-align-right" style="padding-top: 3px; padding-bottom: 3px; padding-right: 8px;"> <?= app\components\DeltaFormatter::formatNumberForUser($modReff->spo_ppn_nominal); ?></td>
