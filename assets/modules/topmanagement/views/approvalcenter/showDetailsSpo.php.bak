												<td style="padding-top: 2px; padding-bottom: 2px; font-size: 1rem; text-align: center; line-height: 1;"><a onclick="penawaranTerpilih('<?= $detail->spod_id ?>')"><i class="fa fa-info-circle"></i> Lihat<br>Penawaran</a></td>
											</tr>
										<?php
											$total += $detail->spod_qty * $detail->spod_harga;
											}
